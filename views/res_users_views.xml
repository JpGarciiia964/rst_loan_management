<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_rst_loan" model="ir.ui.view">
        <field name="name">res.users.form.rst.loan</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='action_id']" position="before">
                <field name="rst_loan_supervisor_id"
                       string="Supervisor de Prestamos"
                       domain="[('groups_id', 'in', %(rst_loan_management.group_rst_loan_supervisor)d)]"
                       groups="rst_loan_management.group_rst_loan_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
