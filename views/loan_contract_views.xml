<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         KANBAN — Solo campos del modelo ORIGINAL en las declaraciones.
         group_draggable="false" impide mover cards entre columnas.
    ═══════════════════════════════════════════════════════ -->
    <record id="view_rst_loan_contract_kanban" model="ir.ui.view">
        <field name="name">rst.loan.contract.kanban</field>
        <field name="model">rst.loan.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    class="o_rst_loan_kanban"
                    group_create="false"
                    group_delete="false"
                    quick_create="false"
                    group_draggable="false"
                    sample="1">

                <field name="name"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="balance_remaining"/>
                <field name="amount_paid"/>
                <field name="progress_percent"/>
                <field name="overdue_amount"/>
                <field name="overdue_installments"/>
                <field name="schedule_count"/>
                <field name="paid_installments"/>
                <field name="state"/>
                <field name="color"/>
                <field name="priority"/>
                <field name="kanban_state"/>
                <field name="loan_type_id"/>
                <field name="date_end"/>
                <field name="date_start"/>
                <field name="loan_officer_id"/>
                <field name="missing_documents"/>
                <field name="currency_id"/>
                <field name="payment_frequency"/>
                <field name="interest_rate"/>
                <field name="term_months"/>
                <field name="partner_classification"/>
                <field name="installment_amount"/>
                <field name="total_late_fees"/>
                <field name="days_to_next_due"/>
                <field name="total_to_pay"/>
                <field name="payment_count"/>
                <field name="cancel_state"/>

                <progressbar field="kanban_state"
                             colors='{"normal": "200", "done": "success", "blocked": "danger"}'/>

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click rst_loan_card
                                           #{record.state.raw_value == 'overdue' ? 'rst_loan_card_overdue' : ''}">

                            <!-- ══ CABECERA ══ -->
                            <div t-attf-class="rst_loan_card_header rst_state_#{record.state.raw_value}">
                                <div class="d-flex flex-column">
                                    <span class="rst_contract_number fw-bold">
                                        <i class="fa fa-file-text-o me-1"/>
                                        <field name="name"/>
                                    </span>
                                    <span class="rst_loan_type">
                                        <field name="loan_type_id"/>
                                        <t t-if="record.payment_frequency.raw_value">
                                            · <field name="payment_frequency"/>
                                        </t>
                                    </span>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <field name="priority" widget="priority"/>
                                    <field name="kanban_state" widget="state_selection"/>
                                </div>
                            </div>

                            <!-- ══ CUERPO ══ -->
                            <div class="rst_loan_card_body">

                                <!-- Cliente + clasificacion + tasa -->
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <img t-att-src="kanban_image('res.partner', 'image_128', record.partner_id.raw_value)"
                                         class="rst_partner_avatar" alt=""/>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="rst_client_name fw-semibold text-truncate">
                                            <field name="partner_id"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <t t-if="record.partner_classification.raw_value">
                                                <span t-attf-class="rst_classification rst_class_#{record.partner_classification.raw_value}">
                                                    <field name="partner_classification"/>
                                                </span>
                                            </t>
                                            <span class="rst_rate_badge">
                                                <i class="fa fa-percent" style="font-size:0.55rem;"/> <field name="interest_rate"/>
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Monto principal -->
                                <div class="rst_main_amount">
                                    <t t-if="record.state.raw_value in ['active', 'overdue']">
                                        <div class="rst_main_amount_label">Saldo Pendiente</div>
                                        <div class="rst_main_amount_value" style="color:#e53935;">
                                            <field name="balance_remaining" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                    </t>
                                    <t t-if="record.state.raw_value == 'paid'">
                                        <div class="rst_main_amount_label">Total Pagado</div>
                                        <div class="rst_main_amount_value" style="color:#2e7d32;">
                                            <field name="amount_paid" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                    </t>
                                    <t t-if="record.state.raw_value in ['draft', 'in_review', 'approved']">
                                        <div class="rst_main_amount_label">Monto Solicitado</div>
                                        <div class="rst_main_amount_value">
                                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                    </t>
                                    <t t-if="record.state.raw_value == 'cancelled'">
                                        <div class="rst_main_amount_label">Monto del Prestamo</div>
                                        <div class="rst_main_amount_value" style="color:#90a4ae; text-decoration:line-through;">
                                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                    </t>
                                </div>

                                <!-- Grid de datos -->
                                <div class="rst_data_grid">
                                    <div class="rst_data_item">
                                        <span class="rst_data_label">Prestamo</span>
                                        <span class="rst_data_value">
                                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </span>
                                    </div>
                                    <div class="rst_data_item">
                                        <span class="rst_data_label">Cuota</span>
                                        <span class="rst_data_value">
                                            <field name="installment_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </span>
                                    </div>
                                    <div class="rst_data_item">
                                        <span class="rst_data_label">Plazo</span>
                                        <span class="rst_data_value">
                                            <field name="term_months"/> meses
                                        </span>
                                    </div>
                                    <div class="rst_data_item">
                                        <span class="rst_data_label">Vencimiento</span>
                                        <span class="rst_data_value">
                                            <field name="date_end"/>
                                        </span>
                                    </div>
                                </div>

                                <!-- Cuotas tracker + progreso (solo activo/vencido) -->
                                <t t-if="record.state.raw_value in ['active', 'overdue', 'paid']">
                                    <div class="rst_installment_tracker">
                                        <div>
                                            <span class="rst_installment_label">Cuotas</span>
                                        </div>
                                        <div class="rst_installment_count">
                                            <span class="paid_num"><field name="paid_installments"/></span>
                                            <span class="total_num"> / <field name="schedule_count"/></span>
                                        </div>
                                        <div class="rst_progress_pct">
                                            <field name="progress_percent"/>%
                                        </div>
                                    </div>
                                    <div class="rst_progress_wrapper">
                                        <div class="rst_progress_bar">
                                            <div t-attf-class="rst_progress_fill
                                                #{record.state.raw_value == 'overdue' ? 'rst_progress_overdue' : ''}
                                                #{record.progress_percent.raw_value >= 100 ? 'rst_progress_complete' : ''}"
                                                 t-attf-style="width: #{Math.min(record.progress_percent.raw_value, 100)}%"/>
                                        </div>
                                    </div>
                                </t>

                                <!-- Alertas -->
                                <div class="d-flex flex-column gap-1 mt-1">
                                    <!-- Cuotas vencidas -->
                                    <t t-if="record.overdue_installments.raw_value > 0">
                                        <div class="rst_overdue_alert">
                                            <i class="fa fa-exclamation-circle"/>
                                            <field name="overdue_installments"/> cuota(s) vencida(s):
                                            <strong><field name="overdue_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong>
                                        </div>
                                    </t>
                                    <!-- Mora acumulada -->
                                    <t t-if="record.total_late_fees.raw_value > 0">
                                        <div class="rst_mora_alert">
                                            <i class="fa fa-clock-o"/>
                                            Mora:
                                            <strong><field name="total_late_fees" widget="monetary" options="{'currency_field': 'currency_id'}"/></strong>
                                        </div>
                                    </t>
                                    <!-- Proximo vencimiento -->
                                    <t t-if="record.state.raw_value in ['active', 'overdue'] and record.days_to_next_due.raw_value != 0">
                                        <div class="text-center">
                                            <t t-if="record.days_to_next_due.raw_value &lt;= 0">
                                                <span class="rst_due_soon rst_due_danger">
                                                    <i class="fa fa-bell"/> Cuota vencida
                                                </span>
                                            </t>
                                            <t t-if="record.days_to_next_due.raw_value > 0 and record.days_to_next_due.raw_value &lt;= 5">
                                                <span class="rst_due_soon rst_due_warning">
                                                    <i class="fa fa-clock-o"/>
                                                    Vence en <field name="days_to_next_due"/> dias
                                                </span>
                                            </t>
                                            <t t-if="record.days_to_next_due.raw_value > 5">
                                                <span class="rst_due_soon rst_due_ok">
                                                    <i class="fa fa-calendar-check-o"/>
                                                    Prox. cuota: <field name="days_to_next_due"/> dias
                                                </span>
                                            </t>
                                        </div>
                                    </t>
                                    <!-- Documentos faltantes -->
                                    <t t-if="record.missing_documents.raw_value > 0">
                                        <div class="rst_docs_alert">
                                            <i class="fa fa-paperclip me-1"/>
                                            <field name="missing_documents"/> doc. obligatorio(s) faltante(s)
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- ══ FOOTER ══ -->
                            <div class="rst_loan_card_footer d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-1 overflow-hidden">
                                    <img t-att-src="kanban_image('res.users', 'image_128', record.loan_officer_id.raw_value)"
                                         class="rst_officer_avatar" alt=""/>
                                    <span class="rst_footer_info text-truncate">
                                        <field name="loan_officer_id"/>
                                    </span>
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0">
                                    <t t-if="record.state.raw_value == 'draft'">
                                        <button class="rst_btn_approve oe_kanban_action"
                                                type="object" name="action_send_to_review"
                                                title="Enviar a Revision">
                                            <i class="fa fa-paper-plane"/>
                                        </button>
                                    </t>
                                    <t t-if="record.state.raw_value == 'in_review'">
                                        <button class="rst_btn_approve oe_kanban_action"
                                                type="object" name="action_approve"
                                                title="Aprobar Contrato">
                                            <i class="fa fa-check"/>
                                        </button>
                                    </t>
                                    <t t-if="record.state.raw_value == 'approved'">
                                        <button class="rst_btn_approve oe_kanban_action"
                                                type="object" name="action_disburse"
                                                title="Desembolsar Prestamo">
                                            <i class="fa fa-money"/>
                                        </button>
                                    </t>
                                    <t t-if="record.state.raw_value in ['active', 'overdue']">
                                        <button class="rst_btn_pay oe_kanban_action btn btn-sm"
                                                type="object" name="action_register_payment"
                                                title="Registrar Pago">
                                            <i class="fa fa-credit-card"/>Pagar
                                        </button>
                                    </t>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LISTA -->
    <record id="view_rst_loan_contract_tree" model="ir.ui.view">
        <field name="name">rst.loan.contract.tree</field>
        <field name="model">rst.loan.contract</field>
        <field name="arch" type="xml">
            <tree string="Contratos de Préstamo"
                  decoration-danger="state == 'overdue'"
                  decoration-success="state == 'paid'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="loan_type_id"/>
                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="interest_rate"/>
                <field name="term_months"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="balance_remaining" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="overdue_amount" widget="monetary" options="{'currency_field': 'currency_id'}" string="Monto Vencido"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ['in_review', 'approved']"
                       decoration-success="state in ['active', 'paid']"
                       decoration-danger="state == 'overdue'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="currency_id" invisible="1"/>
                <field name="loan_officer_id"/>
            </tree>
        </field>
    </record>

    <!-- FORMULARIO -->
    <record id="view_rst_loan_contract_form" model="ir.ui.view">
        <field name="name">rst.loan.contract.form</field>
        <field name="model">rst.loan.contract</field>
        <field name="arch" type="xml">
            <form string="Contrato de Préstamo">

                <header>
                    <button name="action_send_to_review" string="Enviar a Revisión"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_approve" string="✅ Aprobar"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state', '!=', 'in_review')]}"
                            groups="rst_loan_management.group_rst_loan_manager"/>
                    <button name="action_disburse" string="💸 Desembolsar"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'approved')]}"
                            groups="rst_loan_management.group_rst_loan_manager"/>
                    <button name="action_register_payment" string="Registrar Pago"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state', 'not in', ['active', 'overdue'])]}"/>
                    <button name="action_request_cancel" string="Solicitar Cancelacion"
                            type="object" class="btn-warning"
                            attrs="{'invisible': ['|', ('state', 'in', ['draft', 'paid', 'cancelled']), ('cancel_state', 'in', ['requested', 'approved'])]}"
                            confirm="Se enviara una solicitud de cancelacion al supervisor. Continuar?"/>
                    <button name="action_approve_cancel" string="Aprobar Cancelacion"
                            type="object" class="btn-info"
                            attrs="{'invisible': [('cancel_state', '!=', 'requested')]}"
                            groups="rst_loan_management.group_rst_loan_supervisor"
                            confirm="Aprobar la cancelacion de este contrato?"/>
                    <button name="action_reject_cancel" string="Rechazar Cancelacion"
                            type="object" class="btn-secondary"
                            attrs="{'invisible': [('cancel_state', '!=', 'requested')]}"
                            groups="rst_loan_management.group_rst_loan_supervisor"/>
                    <button name="action_cancel" string="Ejecutar Cancelacion"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('cancel_state', '!=', 'approved')]}"
                            groups="rst_loan_management.group_rst_loan_supervisor"
                            confirm="ACCION FINAL: El contrato se marcara como cancelado. Confirma?"/>
                    <button name="action_reset_draft" string="Borrador"
                            type="object"
                            attrs="{'invisible': [('state', 'not in', ['in_review', 'cancelled'])]}"
                            groups="rst_loan_management.group_rst_loan_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_review,approved,active,paid"/>
                </header>

                <div class="alert alert-info mb-0"
                     attrs="{'invisible': [('state', 'not in', ['active', 'overdue', 'paid'])]}">
                    <i class="fa fa-lock me-2"/>
                    <strong>Préstamo desembolsado:</strong> Solo lectura. Para cancelar, un supervisor debe autorizar tras liquidación total.
                </div>
                <div class="alert alert-warning mb-0"
                     attrs="{'invisible': [('missing_documents', '=', 0)]}">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    <strong>Documentos faltantes:</strong>
                    <field name="missing_documents" class="d-inline fw-bold"/> obligatorio(s).
                </div>
                <div class="alert alert-danger mb-0"
                     attrs="{'invisible': [('overdue_installments', '=', 0)]}">
                    <i class="fa fa-exclamation-circle me-2"/>
                    <strong>Cuotas Vencidas:</strong>
                    <field name="overdue_installments" class="d-inline fw-bold"/> -
                    <field name="overdue_amount" widget="monetary"
                           options="{'currency_field': 'currency_id'}" class="d-inline fw-bold"/>
                </div>
                <div class="alert alert-warning mb-0"
                     attrs="{'invisible': [('cancel_state', '!=', 'requested')]}">
                    <i class="fa fa-clock-o me-2"/>
                    <strong>Cancelacion Solicitada:</strong> Pendiente de aprobacion del supervisor.
                </div>
                <div class="alert alert-success mb-0"
                     attrs="{'invisible': [('cancel_state', '!=', 'approved')]}">
                    <i class="fa fa-check-circle me-2"/>
                    <strong>Cancelacion Aprobada:</strong> El cliente debe pagar el saldo pendiente
                    (<field name="balance_remaining" widget="monetary" options="{'currency_field': 'currency_id'}" class="d-inline"/>)
                    + penalidad
                    (<field name="cancellation_penalty_amount" widget="monetary" options="{'currency_field': 'currency_id'}" class="d-inline"/>)
                    para completar la cancelacion.
                </div>

                <field name="cancel_state" invisible="1"/>

                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_schedule" type="object"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="schedule_count" widget="statinfo" string="Cuotas"/>
                        </button>
                        <button name="action_view_payments" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <field name="payment_count" widget="statinfo" string="Pagos"/>
                        </button>
                        <button name="action_view_schedule" type="object"
                                class="oe_stat_button" icon="fa-paperclip">
                            <field name="document_count" widget="statinfo" string="Documentos"/>
                        </button>
                        <button name="action_view_schedule" type="object"
                                class="oe_stat_button" icon="fa-exclamation-triangle"
                                attrs="{'invisible': [('overdue_installments', '=', 0)]}">
                            <field name="overdue_installments" widget="statinfo" string="Vencidas"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="N° Contrato"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="priority" widget="priority"/>
                    </div>

                    <group>
                        <group string="Partes del Contrato">
                            <field name="partner_id"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="partner_classification" widget="badge"
                                   decoration-success="partner_classification == 'preferred'"
                                   decoration-warning="partner_classification == 'normal'"
                                   decoration-danger="partner_classification == 'delinquent'"
                                   attrs="{'invisible': [('partner_classification', '=', False)]}"/>
                            <field name="loan_officer_id"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group string="Tipo de Préstamo">
                            <field name="loan_type_id"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="payment_frequency"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="amortization_method"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                        </group>
                    </group>

                    <group>
                        <group string="Condiciones Financieras">
                            <field name="amount"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="interest_rate"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="term_months"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="installment_amount" readonly="1"/>
                            <field name="total_interest" readonly="1"/>
                            <field name="total_to_pay" readonly="1"/>
                        </group>
                        <group string="Fechas">
                            <field name="date_start"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="date_end" readonly="1"/>
                            <field name="date_approved" readonly="1"
                                   attrs="{'invisible': [('date_approved', '=', False)]}"/>
                            <field name="date_disbursed" readonly="1"
                                   attrs="{'invisible': [('date_disbursed', '=', False)]}"/>
                        </group>
                    </group>

                    <!-- Mora y Días de Gracia -->
                    <group string="Mora y Dias de Gracia" name="group_mora"
                           attrs="{'invisible': [('state', 'in', ['paid', 'cancelled'])]}">
                        <group>
                            <field name="grace_days"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"
                                   help="Dias de gracia tras el vencimiento antes de cobrar mora. 0 = mora inmediata."/>
                            <field name="late_fee_type"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="late_fee_value"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"
                                   help="Si es porcentaje: ej. 2 = 2% del monto de la cuota. Si es fijo: monto exacto."/>
                        </group>
                        <group>
                            <field name="total_late_fees" readonly="1"
                                   attrs="{'invisible': [('total_late_fees', '=', 0)]}"
                                   string="Mora Acumulada"/>
                        </group>
                    </group>

                    <!-- Penalidad por Cancelación Anticipada -->
                    <group string="Penalidad por Cancelacion Anticipada" name="group_penalty"
                           attrs="{'invisible': [('state', 'in', ['paid', 'cancelled'])]}">
                        <group>
                            <field name="cancellation_penalty_type"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"/>
                            <field name="cancellation_penalty_value"
                                   attrs="{'readonly': [('state', 'in', ['active', 'overdue', 'paid'])]}"
                                   help="Porcentaje del saldo pendiente o monto fijo que el cliente paga al cancelar."/>
                        </group>
                        <group>
                            <field name="cancellation_penalty_amount" readonly="1"
                                   attrs="{'invisible': [('cancellation_penalty_amount', '=', 0)]}"
                                   string="Penalidad Calculada"/>
                        </group>
                    </group>

                    <group string="Resumen de Pagos"
                           attrs="{'invisible': [('state', 'in', ['draft', 'in_review', 'approved'])]}">
                        <group>
                            <field name="amount_paid" readonly="1"/>
                            <field name="balance_remaining" readonly="1"/>
                            <field name="overdue_amount" readonly="1"
                                   attrs="{'invisible': [('overdue_amount', '=', 0)]}"/>
                        </group>
                        <group>
                            <field name="progress_percent" widget="progressbar" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📅 Cronograma de Pagos" name="schedule">
                            <field name="schedule_ids" readonly="1">
                                <tree string="Cuotas"
                                      decoration-danger="state == 'overdue'"
                                      decoration-success="state == 'paid'"
                                      decoration-warning="state == 'partial'">
                                    <field name="sequence" string="#"/>
                                    <field name="date_due"/>
                                    <field name="amount_principal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_interest" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_due" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_paid" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_pending" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="balance_after" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="date_paid"/>
                                    <field name="late_fee_amount" widget="monetary"
                                           options="{'currency_field': 'currency_id'}" string="Mora"
                                           attrs="{'invisible': [('late_fee_amount', '=', 0)]}"/>
                                    <field name="late_fee_applied" string="Mora" widget="boolean_toggle" readonly="1"/>
                                    <field name="state" widget="badge"
                                           decoration-danger="state == 'overdue'"
                                           decoration-success="state == 'paid'"
                                           decoration-warning="state == 'partial'"
                                           decoration-info="state == 'pending'"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="💳 Pagos Realizados" name="payments">
                            <field name="payment_ids">
                                <tree string="Pagos"
                                      decoration-muted="state == 'cancelled'"
                                      decoration-success="state == 'confirmed'">
                                    <field name="name"/>
                                    <field name="date_payment"/>
                                    <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="payment_method"/>
                                    <field name="reference"/>
                                    <field name="voucher_number" string="Comprobante"/>
                                    <field name="balance_before" widget="monetary"
                                           options="{'currency_field': 'currency_id'}" string="Saldo Antes"/>
                                    <field name="balance_after" widget="monetary"
                                           options="{'currency_field': 'currency_id'}" string="Saldo Despues"/>
                                    <field name="state" widget="badge"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Documentos" name="documents">
                            <div class="alert alert-secondary mb-3"
                                 attrs="{'invisible': [('loan_type_id', '=', False)]}">
                                <i class="fa fa-info-circle me-1"/>
                                <strong>Documentos requeridos para este tipo de prestamo.</strong>
                                Los marcados como obligatorios deben cargarse antes de aprobar.
                                Suba el archivo en la columna "Documento" de cada fila.
                            </div>
                            <div class="alert alert-info mb-3"
                                 attrs="{'invisible': [('loan_type_id', '!=', False)]}">
                                <i class="fa fa-info-circle me-1"/>
                                Seleccione un tipo de prestamo para cargar los documentos requeridos automaticamente.
                            </div>
                            <field name="document_ids">
                                <tree string="Documentos" editable="bottom"
                                      decoration-danger="state == 'rejected'"
                                      decoration-success="state == 'verified'"
                                      decoration-info="state == 'uploaded'">
                                    <field name="document_type_id" string="Tipo de Documento"
                                           domain="[('loan_type_id', '=', parent.loan_type_id)]"/>
                                    <field name="is_mandatory" string="Obligatorio" readonly="1"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="file_data" widget="binary" filename="file_name"
                                           string="Documento"/>
                                    <field name="date_uploaded" readonly="1" string="Fecha"/>
                                    <field name="expiry_date" string="Vencimiento" optional="hide"/>
                                    <field name="uploaded_by" readonly="1" optional="hide"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'verified'"
                                           decoration-danger="state == 'rejected'"
                                           decoration-warning="state == 'pending'"
                                           decoration-info="state == 'uploaded'"/>
                                    <button name="action_verify" type="object" string="Verificar"
                                            icon="fa-check"
                                            attrs="{'invisible': [('state', 'in', ['verified', 'rejected'])]}"
                                            groups="rst_loan_management.group_rst_loan_manager"/>
                                    <button name="action_reject" type="object" string="Rechazar"
                                            icon="fa-times"
                                            attrs="{'invisible': [('state', 'in', ['verified', 'rejected'])]}"
                                            groups="rst_loan_management.group_rst_loan_manager"/>
                                </tree>
                            </field>
                        </page>

                        <page string="📝 Notas" name="notes">
                            <field name="notes" placeholder="Notas internas..."/>
                            <field name="rejection_reason"
                                   attrs="{'invisible': [('state', 'not in', ['cancelled'])]}"/>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- BÚSQUEDA -->
    <record id="view_rst_loan_contract_search" model="ir.ui.view">
        <field name="name">rst.loan.contract.search</field>
        <field name="model">rst.loan.contract</field>
        <field name="arch" type="xml">
            <search string="Buscar Contratos">
                <field name="name" string="N° Contrato"/>
                <field name="partner_id" string="Cliente"/>
                <field name="loan_type_id"/>
                <field name="loan_officer_id"/>
                <separator/>
                <filter string="Mis Contratos" name="my_contracts"
                        domain="[('loan_officer_id', '=', uid)]"/>
                <filter string="Activos" name="active_contracts"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Vencidos" name="overdue_contracts"
                        domain="[('state', '=', 'overdue')]"/>
                <filter string="En Revisión" name="in_review"
                        domain="[('state', '=', 'in_review')]"/>
                <filter string="Con Cuotas Vencidas" name="has_overdue"
                        domain="[('overdue_installments', '>', 0)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Tipo" name="group_type" context="{'group_by': 'loan_type_id'}"/>
                    <filter string="Oficial" name="group_officer" context="{'group_by': 'loan_officer_id'}"/>
                    <filter string="Cliente" name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACCIÓN PRINCIPAL -->
    <record id="action_rst_loan_contract" model="ir.actions.act_window">
        <field name="name">Contratos de Préstamo</field>
        <field name="res_model">rst.loan.contract</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea tu primer contrato de préstamo</p>
            <p>Gestiona préstamos desde la solicitud hasta el pago final.</p>
        </field>
    </record>

</odoo>
