<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_rst_loan_document_list" model="ir.ui.view">
        <field name="name">rst.loan.document.list</field>
        <field name="model">rst.loan.document</field>
        <field name="arch" type="xml">
            <tree string="Documentos de Préstamos"
                  decoration-danger="state == 'rejected' or is_expired"
                  decoration-success="state == 'verified'"
                  decoration-warning="state == 'pending'">
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="document_type_id"/>
                <field name="is_mandatory" string="Obligatorio"/>
                <field name="file_name"/>
                <field name="file_data" widget="binary" filename="file_name"/>
                <field name="date_uploaded"/>
                <field name="expiry_date"/>
                <field name="uploaded_by"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'verified'"
                       decoration-danger="state in ['rejected']"
                       decoration-warning="state == 'pending'"
                       decoration-info="state == 'uploaded'"/>
                <field name="is_expired" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="action_rst_loan_document" model="ir.actions.act_window">
        <field name="name">Documentos</field>
        <field name="res_model">rst.loan.document</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Sin documentos</p>
            <p>Los documentos se adjuntan desde el formulario de cada contrato.</p>
        </field>
    </record>

</odoo>
