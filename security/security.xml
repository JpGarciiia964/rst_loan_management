<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ═══════════════════════════════════════════════════════
             CATEGORÍA
        ═══════════════════════════════════════════════════════ -->
        <record id="module_category_rst_loans" model="ir.module.category">
            <field name="name">RST Préstamos</field>
            <field name="description">Módulo de gestión de préstamos RST</field>
            <field name="sequence">100</field>
        </record>

        <!-- ═══════════════════════════════════════════════════════
             GRUPOS DE SEGURIDAD
        ═══════════════════════════════════════════════════════ -->

        <!-- Solo Lectura -->
        <record id="group_rst_loan_viewer" model="res.groups">
            <field name="name">Solo Lectura</field>
            <field name="category_id" ref="module_category_rst_loans"/>
            <field name="comment">Puede visualizar préstamos pero no modificarlos.</field>
        </record>

        <!-- Oficial de Crédito -->
        <record id="group_rst_loan_officer" model="res.groups">
            <field name="name">Oficial de Crédito</field>
            <field name="category_id" ref="module_category_rst_loans"/>
            <field name="implied_ids" eval="[(4, ref('group_rst_loan_viewer'))]"/>
            <field name="comment">Puede crear y gestionar contratos y pagos.</field>
        </record>

        <!-- Supervisor (aprueba cancelaciones) -->
        <record id="group_rst_loan_supervisor" model="res.groups">
            <field name="name">Supervisor</field>
            <field name="category_id" ref="module_category_rst_loans"/>
            <field name="implied_ids" eval="[(4, ref('group_rst_loan_officer'))]"/>
            <field name="comment">Puede autorizar cancelaciones de contratos activos.</field>
        </record>

        <!-- Administrador -->
        <record id="group_rst_loan_manager" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_rst_loans"/>
            <field name="implied_ids" eval="[(4, ref('group_rst_loan_supervisor'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Acceso completo: puede aprobar, cancelar y configurar el módulo.</field>
        </record>

        <!-- ═══════════════════════════════════════════════════════
             REGLAS DE REGISTRO
        ═══════════════════════════════════════════════════════ -->

        <!-- Los oficiales de credito ven solo sus propios contratos -->
        <record id="rule_rst_loan_contract_officer" model="ir.rule">
            <field name="name">RST: Oficial ve sus propios contratos</field>
            <field name="model_id" ref="model_rst_loan_contract"/>
            <field name="domain_force">
                ['|',
                 ('loan_officer_id', '=', user.id),
                 ('loan_officer_id', '=', False)]
            </field>
            <field name="groups" eval="[(4, ref('group_rst_loan_officer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Supervisor ve: sus propios + los de oficiales que lo tienen asignado + sin supervisor asignado -->
        <record id="rule_rst_loan_contract_supervisor" model="ir.rule">
            <field name="name">RST: Supervisor ve contratos de sus oficiales</field>
            <field name="model_id" ref="model_rst_loan_contract"/>
            <field name="domain_force">
                ['|', '|', '|',
                 ('loan_officer_id', '=', user.id),
                 ('loan_officer_id.rst_loan_supervisor_id', '=', user.id),
                 ('loan_officer_id.rst_loan_supervisor_id', '=', False),
                 ('loan_officer_id', '=', False)]
            </field>
            <field name="groups" eval="[(4, ref('group_rst_loan_supervisor'))]"/>
        </record>

        <!-- El administrador ve todo -->
        <record id="rule_rst_loan_contract_manager" model="ir.rule">
            <field name="name">RST: Administrador ve todos los contratos</field>
            <field name="model_id" ref="model_rst_loan_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_rst_loan_manager'))]"/>
        </record>

    </data>
</odoo>
