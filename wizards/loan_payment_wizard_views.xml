<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_rst_loan_payment_wizard_form" model="ir.ui.view">
        <field name="name">rst.loan.payment.wizard.form</field>
        <field name="model">rst.loan.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Pago">
                <sheet>
                    <div class="alert alert-info mb-3">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>Contrato:</strong>
                        <field name="contract_id" readonly="1" class="d-inline ms-1"/>
                        -
                        <strong>Cliente:</strong>
                        <field name="partner_id" readonly="1" class="d-inline ms-1"/>
                    </div>

                    <div class="text-center mb-3">
                        <h5 class="text-muted">Saldo Pendiente</h5>
                        <h2 class="text-danger fw-bold">
                            <field name="balance_remaining" readonly="1"/>
                        </h2>
                        <div attrs="{'invisible': [('overdue_amount', '=', 0)]}">
                            <span class="badge bg-danger">
                                Monto vencido:
                                <field name="overdue_amount" readonly="1" class="d-inline"/>
                            </span>
                        </div>
                    </div>

                    <!-- Alertas mora/cancelacion -->
                    <div class="alert alert-warning mb-3"
                         attrs="{'invisible': [('has_late_fee', '=', False)]}">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Mora aplicada a esta cuota:</strong>
                        <field name="late_fee_amount" readonly="1" class="d-inline ms-1"/>
                        <br/>
                        <small class="text-muted">
                            Mora acumulada total:
                            <field name="contract_total_late_fees" readonly="1" class="d-inline"/>
                        </small>
                    </div>
                    <div class="alert alert-success mb-3"
                         attrs="{'invisible': [('cancel_state', '!=', 'approved')]}">
                        <i class="fa fa-check-circle me-2"/>
                        <strong>Cancelacion aprobada.</strong> Total requerido:
                        <field name="full_payoff_amount" readonly="1" class="d-inline ms-1 fw-bold"/>
                    </div>
                    <div class="alert alert-danger mb-3"
                         attrs="{'invisible': ['|', ('has_penalty', '=', False), ('cancel_state', '=', 'approved')]}">
                        <i class="fa fa-ban me-2"/>
                        <strong>Penalidad por cancelacion:</strong>
                        <field name="cancellation_penalty" readonly="1" class="d-inline ms-1"/>
                    </div>

                    <field name="cancel_state" invisible="1"/>
                    <field name="full_payoff_amount" invisible="1"/>
                    <field name="has_late_fee" invisible="1"/>
                    <field name="has_penalty" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <group>
                        <group string="Cuota a Pagar">
                            <field name="next_installment_id"/>
                            <field name="installment_amount" readonly="1" string="Monto de la Cuota"/>
                            <field name="installment_date_due" readonly="1" string="Fecha de Vencimiento"/>
                            <field name="installment_state" readonly="1" string="Estado"
                                   widget="badge"
                                   decoration-danger="installment_state == 'overdue'"
                                   decoration-warning="installment_state == 'partial'"
                                   decoration-info="installment_state == 'pending'"/>
                        </group>
                        <group string="Datos del Pago">
                            <field name="date_payment"/>
                            <field name="amount"/>
                            <field name="payment_method"/>
                            <field name="reference"
                                   attrs="{'invisible': [('payment_method', '!=', 'other')]}"/>
                        </group>
                    </group>

                    <!-- ══ EFECTIVO: Denominaciones ══ -->
                    <div attrs="{'invisible': [('payment_method', '!=', 'cash')]}"
                         style="margin: 8px 0;">
                        <h5 style="font-weight:600; margin-bottom:8px;">Denominaciones de Billetes / Monedas</h5>
                        <field name="denomination_ids" nolabel="1">
                            <tree editable="bottom" no_open="1" create="0" delete="0">
                                <field name="denomination" string="Billete / Moneda (RD$)" readonly="1"/>
                                <field name="quantity" string="Cantidad"/>
                                <field name="subtotal" string="Subtotal (RD$)" readonly="1"/>
                            </tree>
                        </field>
                        <div class="d-flex justify-content-end align-items-center mt-3 mb-2"
                             style="padding-right:8px; font-size:15px;">
                            <strong class="me-2">Total Efectivo Recibido:</strong>
                            <field name="cash_total" readonly="1"
                                   style="font-size:16px; font-weight:bold;"/>
                        </div>
                    </div>

                    <!-- ══ TRANSFERENCIA ══ -->
                    <group string="Datos de la Transferencia"
                           attrs="{'invisible': [('payment_method', '!=', 'transfer')]}">
                        <group>
                            <field name="transfer_ref" string="No. Comprobante"
                                   attrs="{'required': [('payment_method', '=', 'transfer')]}"/>
                            <field name="transfer_bank" string="Banco Emisor"
                                   attrs="{'required': [('payment_method', '=', 'transfer')]}"/>
                        </group>
                        <group>
                            <field name="transfer_amount" string="Monto Transferido"
                                   attrs="{'required': [('payment_method', '=', 'transfer')]}"/>
                        </group>
                    </group>

                    <!-- ══ CHEQUE ══ -->
                    <group string="Datos del Cheque"
                           attrs="{'invisible': [('payment_method', '!=', 'check')]}">
                        <group>
                            <field name="check_number" string="No. Cheque"
                                   attrs="{'required': [('payment_method', '=', 'check')]}"/>
                            <field name="check_bank" string="Banco Emisor"
                                   attrs="{'required': [('payment_method', '=', 'check')]}"/>
                        </group>
                        <group>
                            <field name="check_issuer" string="Nombre del Emisor"
                                   attrs="{'required': [('payment_method', '=', 'check')]}"/>
                            <field name="check_amount" string="Monto del Cheque"
                                   attrs="{'required': [('payment_method', '=', 'check')]}"/>
                        </group>
                    </group>

                    <group string="Notas"
                           attrs="{'invisible': [('payment_method', 'in', ['cash', 'transfer', 'check'])]}">
                        <field name="notes" nolabel="1" placeholder="Observaciones del pago..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_register_payment" string="Confirmar Pago e Imprimir Boleta"
                            type="object" class="btn-success"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
